<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h4 class="mb-1">
        <%= @template.name %>
        <% if @template.is_preset? %>
          <span class="badge bg-warning text-dark ms-2">プリセット</span>
        <% end %>
      </h4>
      <p class="text-muted mb-0"><%= @template.description %></p>
    </div>
    <div class="d-flex gap-2">
      <% unless @template.is_preset? %>
        <%= link_to "編集", edit_manual_template_path(@template), class: "btn btn-outline-primary" %>
      <% end %>
      <%= button_to "複製", duplicate_manual_template_path(@template), method: :post, class: "btn btn-outline-secondary" %>
      <%= link_to "一覧に戻る", manual_templates_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-list-ol"></i> セクション構造</h6>
        </div>
        <div class="card-body p-0">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th style="width: 40px;">#</th>
                <th>セクション名</th>
                <th>生成指示</th>
              </tr>
            </thead>
            <tbody>
              <% @template.sections.each_with_index do |section, index| %>
                <tr>
                  <td class="text-muted"><%= index + 1 %></td>
                  <td class="fw-bold"><%= section['name'] %></td>
                  <td class="text-muted"><%= section['instruction'] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card mb-3">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-info-circle"></i> テンプレート情報</h6>
        </div>
        <div class="card-body">
          <dl class="mb-0">
            <dt class="text-muted small">出力形式</dt>
            <dd><%= @template.output_format_markdown? ? 'Markdown' : 'DOCX' %></dd>
            <dt class="text-muted small">タイプ</dt>
            <dd><%= @template.is_preset? ? 'プリセット' : 'カスタム' %></dd>
            <dt class="text-muted small">作成日時</dt>
            <dd><%= l(@template.created_at, format: :long) rescue @template.created_at.strftime('%Y/%m/%d %H:%M') %></dd>
          </dl>
        </div>
      </div>

    </div>
  </div>
</div>
