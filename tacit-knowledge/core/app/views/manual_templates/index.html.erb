<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-file-earmark-text"></i> テンプレート管理</h4>
    <%= link_to new_manual_template_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-lg"></i> 新規テンプレート作成
    <% end %>
  </div>

  <% if @templates.any? %>
    <%# プリセットテンプレート %>
    <% presets = @templates.select(&:is_preset?) %>
    <% if presets.any? %>
      <h5 class="text-muted mb-3"><i class="bi bi-star-fill text-warning"></i> プリセットテンプレート</h5>
      <div class="row g-3 mb-4">
        <% presets.each do |template| %>
          <div class="col-md-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <h6 class="card-title"><%= template.name %></h6>
                <p class="card-text text-muted small"><%= truncate(template.description, length: 80) %></p>
                <div class="mb-2">
                  <% template.sections.each_with_index do |section, i| %>
                    <% break if i >= 3 %>
                    <span class="badge bg-light text-dark border me-1 mb-1"><%= section['name'] %></span>
                  <% end %>
                  <% if template.sections.size > 3 %>
                    <span class="badge bg-light text-muted border">+<%= template.sections.size - 3 %></span>
                  <% end %>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0">
                <div class="d-flex gap-2">
                  <%= link_to "詳細", manual_template_path(template), class: "btn btn-sm btn-outline-secondary" %>
                  <%= button_to "複製", duplicate_manual_template_path(template), method: :post, class: "btn btn-sm btn-outline-primary" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# カスタムテンプレート %>
    <% customs = @templates.reject(&:is_preset?) %>
    <% if customs.any? %>
      <h5 class="text-muted mb-3"><i class="bi bi-person-gear"></i> カスタムテンプレート</h5>
      <div class="row g-3">
        <% customs.each do |template| %>
          <div class="col-md-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <h6 class="card-title"><%= template.name %></h6>
                <p class="card-text text-muted small"><%= truncate(template.description, length: 80) %></p>
                <div class="mb-2">
                  <% template.sections.each_with_index do |section, i| %>
                    <% break if i >= 3 %>
                    <span class="badge bg-light text-dark border me-1 mb-1"><%= section['name'] %></span>
                  <% end %>
                  <% if template.sections.size > 3 %>
                    <span class="badge bg-light text-muted border">+<%= template.sections.size - 3 %></span>
                  <% end %>
                </div>
              </div>
              <div class="card-footer bg-transparent border-top-0">
                <div class="d-flex gap-2">
                  <%= link_to "詳細", manual_template_path(template), class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to "編集", edit_manual_template_path(template), class: "btn btn-sm btn-outline-primary" %>
                  <%= button_to "複製", duplicate_manual_template_path(template), method: :post, class: "btn btn-sm btn-outline-secondary" %>
                  <%= link_to "削除", manual_template_path(template), method: :delete, data: { turbo_method: :delete, turbo_confirm: "このテンプレートを削除してもよろしいですか？" }, class: "btn btn-sm btn-outline-danger" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <div class="text-center text-muted py-5">
      <i class="bi bi-file-earmark-text" style="font-size: 3rem;"></i>
      <p class="mt-3">テンプレートがまだありません。</p>
      <p><%= link_to "テンプレートを作成する", new_manual_template_path, class: "btn btn-primary" %></p>
    </div>
  <% end %>
</div>
