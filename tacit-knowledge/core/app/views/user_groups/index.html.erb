<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
      <i class="bi bi-people me-2"></i><%= @title %>
    </h4>
    <%= link_to new_user_group_path, class: "btn btn-primary" do %>
      <i class="bi bi-plus-circle me-1"></i>新規グループ作成
    <% end %>
  </div>

  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>

  <div class="card">
    <div class="card-body">
      <% if @user_groups.any? %>
        <table class="table table-bordered mb-0">
          <thead>
            <tr>
              <th>グループ名</th>
              <th>メンバー数</th>
              <th>説明</th>
              <% if privileged_admin? %><th>会社</th><% end %>
              <th>作成日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @user_groups.each do |group| %>
              <tr>
                <td><%= group.name %></td>
                <td>
                  <span class="badge bg-info"><%= group.members_count %>名</span>
                </td>
                <td><%= truncate(group.description, length: 50) %></td>
                <% if privileged_admin? %><td><%= group.company&.name %></td><% end %>
                <td><%= group.created_at.strftime("%Y/%m/%d") %></td>
                <td>
                  <%= link_to members_user_group_path(group), class: "btn btn-sm btn-outline-primary me-1" do %>
                    <i class="bi bi-people me-1"></i>管理
                  <% end %>
                  <%= link_to edit_user_group_path(group), class: "btn btn-sm btn-outline-secondary me-1" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= link_to user_group_path(group),
                              method: :delete,
                              data: { turbo_method: :delete, turbo_confirm: "このグループを削除しますか？" },
                              class: "btn btn-sm btn-outline-danger" do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted mb-0">
          <i class="bi bi-info-circle me-1"></i>
          グループがまだ作成されていません。
        </p>
      <% end %>
    </div>
  </div>
</div>
