<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
      <i class="bi bi-people me-2"></i><%= @title %>
    </h4>
    <%= link_to user_groups_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i>戻る
    <% end %>
  </div>

  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>

  <!-- メンバー追加フォーム -->
  <% if @available_users.any? %>
    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>メンバーを追加</h5>
      </div>
      <div class="card-body">
        <%= form_with(url: add_members_user_group_path(@user_group), method: :post, local: true) do %>
          <div class="row mb-3">
            <div class="col-md-4">
              <label class="form-label">部署で絞り込み</label>
              <select id="department-filter" class="form-select" onchange="filterUsers()">
                <option value="">全て</option>
                <% @available_users.map(&:department).compact.uniq.sort.each do |dept| %>
                  <option value="<%= dept %>"><%= dept %></option>
                <% end %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">役職で絞り込み</label>
              <select id="role-filter" class="form-select" onchange="filterUsers()">
                <option value="">全て</option>
                <option value="company_admin">管理者</option>
                <option value="veteran">熟練者</option>
                <option value="general">一般</option>
              </select>
            </div>
          </div>

          <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
            <table class="table table-bordered table-sm mb-0">
              <thead class="table-light sticky-top">
                <tr>
                  <th style="width: 40px;">
                    <input type="checkbox" id="select-all" onchange="toggleAll(this)">
                  </th>
                  <th>氏名</th>
                  <th>部署</th>
                  <th>役職</th>
                </tr>
              </thead>
              <tbody id="user-list">
                <% @available_users.each do |user| %>
                  <tr class="user-row" data-department="<%= user.department %>" data-role="<%= user.role %>">
                    <td>
                      <input type="checkbox" name="user_ids[]" value="<%= user.id %>" class="user-checkbox">
                    </td>
                    <td><%= user.name %></td>
                    <td><%= user.department %></td>
                    <td>
                      <span class="badge bg-<%= user.role_company_admin? ? 'warning' : user.role_veteran? ? 'success' : 'secondary' %>">
                        <%= user.role_i18n rescue user.role %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="mt-3 d-flex justify-content-between align-items-center">
            <span id="selected-count" class="text-muted">0名選択中</span>
            <%= submit_tag "選択したユーザーを追加", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 現在のメンバー一覧 -->
  <div class="card">
    <div class="card-header">
      <h5 class="mb-0">
        <i class="bi bi-people-fill me-2"></i>現在のメンバー
        <span class="badge bg-info ms-2"><%= @memberships.size %>名</span>
      </h5>
    </div>
    <div class="card-body">
      <% if @memberships.any? %>
        <table class="table table-bordered mb-0">
          <thead>
            <tr>
              <th>氏名</th>
              <th>部署</th>
              <th>役職</th>
              <th>追加日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @memberships.each do |membership| %>
              <tr>
                <td><%= membership.user.name %></td>
                <td><%= membership.user.department %></td>
                <td>
                  <span class="badge bg-<%= membership.user.role_company_admin? ? 'warning' : membership.user.role_veteran? ? 'success' : 'secondary' %>">
                    <%= membership.user.role_i18n rescue membership.user.role %>
                  </span>
                </td>
                <td><%= membership.created_at.strftime("%Y/%m/%d") %></td>
                <td>
                  <%= link_to remove_member_user_group_path(@user_group, user_id: membership.user_id),
                              method: :delete,
                              data: { turbo_method: :delete, turbo_confirm: "#{membership.user.name} をグループから削除しますか？" },
                              class: "btn btn-sm btn-outline-danger" do %>
                    <i class="bi bi-person-dash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-muted mb-0">
          <i class="bi bi-info-circle me-1"></i>
          メンバーがまだ追加されていません。
        </p>
      <% end %>
    </div>
  </div>
</div>

<script>
  function filterUsers() {
    const deptFilter = document.getElementById("department-filter").value;
    const roleFilter = document.getElementById("role-filter").value;
    const rows = document.querySelectorAll(".user-row");

    rows.forEach(function(row) {
      const dept = row.dataset.department || "";
      const role = row.dataset.role || "";
      const deptMatch = !deptFilter || dept === deptFilter;
      const roleMatch = !roleFilter || role === roleFilter;
      row.style.display = (deptMatch && roleMatch) ? "" : "none";
    });

    document.getElementById("select-all").checked = false;
  }

  function toggleAll(masterCheckbox) {
    const rows = document.querySelectorAll(".user-row");
    rows.forEach(function(row) {
      if (row.style.display !== "none") {
        const cb = row.querySelector(".user-checkbox");
        if (cb) cb.checked = masterCheckbox.checked;
      }
    });
    updateSelectedCount();
  }

  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".user-checkbox").forEach(function(cb) {
      cb.addEventListener("change", updateSelectedCount);
    });
  });

  function updateSelectedCount() {
    const count = document.querySelectorAll(".user-checkbox:checked").length;
    const el = document.getElementById("selected-count");
    if (el) el.textContent = count + "名選択中";
  }
</script>
