<% provide(:title, '確認メール再送信') %>

<div class="login">
  <div class="align-items-center d-flex justify-content-center logo">
    <h2>確認メール再送信</h2>
  </div>

  <div class="d-flex justify-content-center mt-4">
    <div class="col-8 col-lg-6 col-xl-4">
      <p class="text-muted text-center mb-4">
        登録時に送信された確認メールが届いていない場合は、以下のフォームからメールアドレスを入力して再送信してください。
      </p>

      <%= form_tag(confirmation_path, method: :post, data: { turbo: false }) do %>
        <div class="mb-3">
          <label for="email" class="form-label">メールアドレス</label>
          <%= text_field_tag :email, nil, class: "form-control", placeholder: "example@example.com", required: true %>
        </div>

        <div class="mb-3">
          <label for="type" class="form-label">アカウントタイプ</label>
          <%= select_tag :type, options_for_select([["管理者", "admin"], ["ユーザー", "user"]], "admin"), class: "form-select" %>
        </div>

        <div class="d-flex mt-4 justify-content-center">
          <%= submit_tag "確認メールを再送信", class: "btn btn-secondary col-8 py-2 rounded-pill" %>
        </div>
      <% end %>

      <div class="d-flex mt-4 justify-content-center">
        <%= link_to "ログイン画面に戻る", login_path, class: "text-muted" %>
      </div>
    </div>
  </div>
</div>
