<div class="col-md-10 p-4 p-lg-5 w-100 pt-lg-0">
  <div class="d-flex justify-content-end">
    <%= link_to "+ 新規会社登録", new_company_path, class: "btn bg-secondary text-white mb-4" %>
  </div>
  <div class="table-container">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>会社名</th>
          <th>説明</th>
          <th>ステータス</th>
          <th>管理者数</th>
          <th>ユーザー数</th>
          <th>トピック数</th>
          <th>アクション</th>
        </tr>
      </thead>
      <tbody>
        <% if @companies.any? %>
          <% @companies.each do |company| %>
            <tr>
              <td><%= company.name %></td>
              <td><%= truncate(company.description, length: 30, separator: '...') %></td>
              <td>
                <% if company.status_active? %>
                  <span class="badge bg-success">有効</span>
                <% else %>
                  <span class="badge bg-secondary">無効</span>
                <% end %>
              </td>
              <td><%= company.admins.count %></td>
              <td><%= company.users.count %></td>
              <td><%= company.topics.count %></td>
              <td>
                <div class="d-flex gap-2">
                  <%= button_to "編集", edit_company_path(company), method: :get, class: "btn bg-secondary text-white btn-sm" %>
                  <%= button_to "削除", company_path(company), method: :delete,
                      class: "btn text-danger btn-sm",
                      data: { confirm: "本当に削除しますか？" } %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7" class="text-center text-muted py-4">
              <i class="fas fa-inbox fa-2x mb-2"></i><br>
              データがありません
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="d-flex justify-content-end mt-4">
    <%= paginate @companies %>
  </div>
</div>
