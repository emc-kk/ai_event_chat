<nav aria-label="フォルダパス" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item">
      <% if @current_folder.present? %>
        <%= link_to topics_path do %>
          <i class="bi bi-house-door"></i> ルート
        <% end %>
      <% else %>
        <i class="bi bi-house-door"></i> ルート
      <% end %>
    </li>
    <% @breadcrumb.each do |folder| %>
      <li class="breadcrumb-item <%= 'active' if folder == @current_folder %>">
        <% if folder == @current_folder %>
          <i class="bi bi-folder-fill text-warning"></i> <%= folder.name %>
        <% else %>
          <%= link_to topics_path(folder_id: folder.id) do %>
            <i class="bi bi-folder-fill text-warning"></i> <%= folder.name %>
          <% end %>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
