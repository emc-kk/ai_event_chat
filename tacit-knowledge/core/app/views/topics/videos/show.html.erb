<div class="container-fluid py-4" data-controller="manual-video">
  <h4 class="fw-bold mb-4"><%= @movie_title %></h4>

  <div class="row">
    <%# 左サイドバー（チャプターリスト） %>
    <div class="col-md-3">
      <div class="chapter-header text-white text-center py-2 fw-bold rounded-top">
        動画のチャプター
      </div>

      <div class="border border-top-0 rounded-bottom" style="max-height: 400px; overflow-y: auto;">
        <%= render partial: 'chapter', collection: @chapters, as: :chapter %>
      </div>

      <%= link_to '動画を登録 / 変更', '#',
                  class: 'btn open-movie-btn text-white w-100 mt-3',
                  data: { bs_toggle: 'modal', bs_target: '#videoUploadModal' } %>

      <%= link_to 'テキスト編集に戻る', topic_manual_path(topic_id: params[:topic_id], id: params[:manual_id]), class: "btn btn-secondary w-100 mt-3" %>
    </div>

    <%# 右側（動画プレイヤー＆文字起こし） %>
    <div class="col-md-9">
      <%# 動画プレイヤー %>
      <div class="bg-dark rounded overflow-hidden mb-3">
        <video id="video-element"
               data-manual-video-target="video"
               class="w-100"
               controls
               src="<%= @video_url %>"
               style="max-height: 400px;">
          恐れ入りますが、このブラウザーは埋め込み動画に対応していません。
        </video>
      </div>

      <%# 文字起こしセクション %>
      <div class="card">
        <div class="card-body">
          <h5 class="fw-bold mb-3">動画：文字起こし</h5>

          <div id="transcript-container"
               data-manual-video-target="transcript"
               style="max-height: 300px; overflow-y: auto;">

            <%# 文字起こしアイテム %>
            <%= render partial: 'transcript', collection: @transcriptions, as: :transcription %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%= render "reupload_dialog" %>
