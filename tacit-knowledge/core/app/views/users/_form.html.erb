<%= form_with(model: @user, local: true, class: "needs-validation", html: { novalidate: true },
    data: { controller: "bootstrap-validation", action: "submit->bootstrap-validation#validate", turbo: false }) do |form| %>
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :email, "メールアドレス", class: "form-label fw-bold required" %>
    <%= form.email_field :email, class: "form-control #{'is-invalid' if @user.errors[:email].present? }", placeholder: "メールアドレスを入力してください", required: true %>
    <div class="invalid-feedback">
      有効なメールアドレスを入力してください。
    </div>
    <% unless @user.new_record? %>
      <div class="form-text text-muted">
        メールアドレスを変更すると確認状態が「未確認」にリセットされ、新しい確認メールが送信されます。
      </div>
    <% end %>
  </div>

  <% if @user.new_record? %>
    <div class="mb-3">
      <%= form.label :password, "パスワード", class: "form-label fw-bold required" %>
      <%= form.password_field :password, class: "form-control #{'is-invalid' if @user.errors[:password].present? }", placeholder: "パスワードを入力してください", required: true , minlength: 8 %>
       <div class="form-text text-muted">
        8文字以上で、大文字・小文字・数字・記号を含む必要があります
      </div>
      <div class="invalid-feedback">
        パスワードは8文字以上で、大文字・小文字・数字・記号をそれぞれ含む必要があります。
      </div>
    </div>

    <div class="mb-3">
      <%= form.label :password_confirmation, "パスワード確認", class: "form-label fw-bold required" %>
      <%= form.password_field :password_confirmation, class: "form-control #{'is-invalid' if @user.errors[:password_confirmation].present? }", placeholder: "パスワードを再入力してください", required: true %>
      <div class="form-text text-muted">
        上記で入力したパスワードと同じものを入力してください
      </div>
      <div class="invalid-feedback">
        パスワードが一致しません。同じパスワードを入力してください。
      </div>
    </div>

    <% if privileged_admin? %>
      <div class="mb-3">
        <%= form.label :company_id, "会社", class: "form-label fw-bold required" %>
        <%= form.select :company_id,
            options_for_select(
              Company.all.map { |c| [c.name, c.id] },
              @user.company_id
            ),
            { include_blank: "会社を選択してください" },
            class: "form-select", required: true %>
        <div class="invalid-feedback">
          会社を選択してください。
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="mb-3">
      <label class="form-label fw-bold">パスワード再設定</label>
      <div class="form-text text-muted mb-2">
        パスワードを変更する場合のみ入力してください。空欄の場合は変更されません。
      </div>
      <%= form.password_field :password, class: "form-control #{'is-invalid' if @user.errors[:password].present? }", placeholder: "新しいパスワード", minlength: 8 %>
      <div class="form-text text-muted">
        8文字以上で、大文字・小文字・数字・記号を含む必要があります
      </div>
    </div>

    <div class="mb-3">
      <%= form.password_field :password_confirmation, class: "form-control #{'is-invalid' if @user.errors[:password_confirmation].present? }", placeholder: "新しいパスワード（確認）" %>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "氏名", class: "form-label fw-bold required" %>
    <%= form.text_field :name, class: "form-control #{'is-invalid' if @user.errors[:name].present? }", placeholder: "ユーザーの氏名", required: true %>
    <div class="invalid-feedback">
      氏名を入力してください。
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :department, "所属部署", class: "form-label fw-bold" %>
    <%= form.text_field :department, class: "form-control #{'border-danger' if @user.errors[:department].present? }", placeholder: "所属部署名" %>
  </div>

  <div class="mb-3">
    <%= form.label :role, "権限", class: "form-label fw-bold" %>
    <div style="display: flex; gap: 1rem;">
      <div>
        <%= form.radio_button :role, 'general', checked: @user.new_record? || @user.role_general?, class: 'form-check-input' %>
        <%= form.label :role_general, '一般', class: 'form-check-label' %>
      </div>
      <div>
        <%= form.radio_button :role, 'veteran', checked: !@user.new_record? && @user.role_veteran?, class: 'form-check-input' %>
        <%= form.label :role_veteran, '熟練者', class: 'form-check-label' %>
      </div>
      <div>
        <%= form.radio_button :role, 'company_admin', checked: @user.role_company_admin?, class: 'form-check-input' %>
        <%= form.label :role_company_admin, '管理者', class: 'form-check-label' %>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :number, "勤続年数", class: "form-label fw-bold" %>
    <%= form.text_field :number, class: "form-control #{'border-danger' if @user.errors[:number].present? }", placeholder: "例: 25" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, "社内経歴", class: "form-label fw-bold" %>
    <%= form.text_area :description, class: "form-control #{'border-danger' if @user.errors[:description].present? }", rows: 6, placeholder: "主要な役職や担当業務などの経歴を入力" %>
  </div>

  <div class="d-flex gap-2 justify-content-end">
    <%= link_to "キャンセル", users_path, class: "btn btn-secondary" %>
    <%= form.submit (@user.new_record? ? "登録" : "更新"), class: "btn btn-primary" %>
  </div>
<% end %>
