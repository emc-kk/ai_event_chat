<div class="col-md-10 p-4 p-lg-5 w-100 pt-lg-0">
  <div class="mb-3">
    <h3>ヒアリング詳細</h3>
  </div>

  <div class="card mb-3">
    <div class="card-body">
      <div class="row mb-3">
        <div class="col-md-3">
          <strong>トピック</strong>
        </div>
        <div class="col-md-9">
          <%= @request.topic&.name %>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-3">
          <strong>熟練者</strong>
        </div>
        <div class="col-md-9">
          <%= @request.respondent&.name %>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-3">
          <strong>ヒアリング名</strong>
        </div>
        <div class="col-md-9">
          <%= @request.name %>
        </div>
      </div>

      <% if @request.description.present? %>
        <div class="row mb-3">
          <div class="col-md-3">
            <strong>説明</strong>
          </div>
          <div class="col-md-9">
            <%= simple_format(@request.description) %>
          </div>
        </div>
      <% end %>

      <div class="row mb-3">
        <div class="col-md-3">
          <strong>ステータス</strong>
        </div>
        <div class="col-md-9">
          <span class="status-badge status-<%= @request.status.gsub("_", "-") %>">
            <%= t("activerecord.attributes.request.statuses.#{@request.status}") %>
          </span>
        </div>
      </div>

      <% if @request.request_documents.any? %>
        <div class="row mb-3">
          <div class="col-md-3">
            <strong>添付ファイル</strong>
          </div>
          <div class="col-md-9">
            <ul class="list-unstyled mb-0">
              <% @request.request_documents.each do |document| %>
                <li class="mb-2">
                  <i class="bi bi-file-earmark me-2"></i>
                  <span><%= File.basename(document.key) %></span>
                  <span class="badge bg-secondary ms-2">
                    <%= t("activerecord.attributes.request_document.statuses.#{document.status}") %>
                  </span>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= link_to "戻る", topics_path, class: "btn btn-secondary" %>
    <% if can_access_chat?(@request, 'hearing') %>
      <% hearing_path = latest_room_path(@request, 'hearing') || hearing_request_path(@request) %>
      <%= link_to "ヒアリング用チャット", hearing_path, class: "btn btn-primary" %>
    <% else %>
      <button class="btn btn-secondary" disabled>ヒアリング用チャット</button>
    <% end %>
  </div>
</div>

