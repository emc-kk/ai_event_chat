<% request_data.each do |requests| %>
  <div class="m-4">
    <h5 class="mb-3"><%= requests[:title] %></h5>
    <div class="table-container">
      <table class="table table-hover mb-0">
        <thead>
            <tr>
              <th>トピック名</th>
              <th><%= requests[:is_history] ? "完了日" : "依頼日" %></th>
              <th>アクション</th>
            </tr>
        </thead>
        <tbody>
          <% if requests[:data]&.any? %>
            <% requests[:data].each do |request| %>
              <tr>
                  <td><%= request.topic.name %></td>
                  <td><%= request.updated_at.strftime("%Y/%m/%d") %></td>
                  <td>
                    <%= link_to "#{requests[:is_history] ? "履歴を見る" : "開始する"}", request_path(request), class: "btn #{requests[:is_history] ? 'text-secondary' : 'btn-secondary'} btn-sm" %>
                  </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="text-center text-muted py-4">
                <i class="fas fa-inbox fa-2x mb-2"></i><br>
                データがありません
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-end mt-4">
      <%= paginate requests[:data], param_name: requests[:param_name] %>
    </div>
  </div>
<% end %>
